{
	"name": "@ingram-tech/registry",
	"version": "0.0.0",
	"private": true,
	"description": "Ingram Technologies' shadcn-style component registry. Copy-in, own-and-rebrand components shared across the fleet. Currently: transactional email (React Email).",
	"homepage": "https://github.com/ingram-technologies/registry#readme",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ingram-technologies/registry.git"
	},
	"type": "module",
	"scripts": {
		"build": "shadcn build",
		"lint": "oxlint",
		"format": "oxfmt --write .",
		"check": "oxlint && oxfmt --check . && bun run scripts/check-site-names.ts",
		"type-check": "tsc --noEmit",
		"preview": "email dev --dir preview",
		"test": "vitest run"
	},
	"devDependencies": {
		"@react-email/components": "^1.0.12",
		"@react-email/render": "^2.0.10",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-email": "^4.0.0",
		"shadcn": "^4.13.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "bun@1.3.14"
}
