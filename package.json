{
	"name": "@ingram-tech/registry",
	"version": "0.0.0",
	"private": true,
	"description": "Ingram Technologies' shadcn-style component registry. Copy-in, own-and-rebrand components shared across the fleet. Currently: transactional email (React Email) and the shared dashboard ui kit (Base UI + Tailwind v4).",
	"homepage": "https://github.com/ingram-technologies/registry#readme",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ingram-technologies/registry.git"
	},
	"type": "module",
	"scripts": {
		"build": "shadcn build",
		"lint": "oxlint",
		"format": "oxfmt --write .",
		"check": "oxlint && oxfmt --check . && bun run scripts/check-site-names.ts",
		"type-check": "tsc --noEmit",
		"preview": "email dev --dir preview",
		"test": "vitest run"
	},
	"devDependencies": {
		"@base-ui/react": "^1.6.0",
		"@react-email/components": "^1.0.12",
		"@react-email/render": "^2.0.10",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"happy-dom": "^20.10.6",
		"lucide-react": "^1.23.0",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-email": "^6.6.8",
		"shadcn": "^4.13.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "bun@1.3.14"
}
